set(SDL_MIXER_ROOT ${CMAKE_CURRENT_SOURCE_DIR}/third_party/SDL_mixer)
set(SDL_MIXER_BUILD_DIR ${CMAKE_BINARY_DIR}/SDL_mixer-build)
set(SDL_MIXER_INSTALL_DIR ${CMAKE_BINARY_DIR}/SDL_mixer-install)
set(SDL_MIXER_INCLUDE_DIR ${SDL_MIXER_INSTALL_DIR}/include)
set(SDL_MIXER_LIBRARY_DIR ${SDL_MIXER_INSTALL_DIR}/lib)

include(ExternalProject)

ExternalProject_Add(3rd_SDL_mixer
    SOURCE_DIR  ${SDL_MIXER_ROOT}
    BINARY_DIR  ${SDL_MIXER_BUILD_DIR}
    INSTALL_DIR ${SDL_MIXER_INSTALL_DIR}
    CMAKE_CACHE_ARGS
        -DBUILD_SHARED_LIBS:BOOL=OFF
        -DBUILD_TESTING:BOOL=OFF
        -DSDL2MIXER_DEPS_SHARED:BOOL=OFF
        -DSDL2MIXER_VENDORED:BOOL=ON
        -DCMAKE_INSTALL_PREFIX:PATH=<INSTALL_DIR>
)

file(MAKE_DIRECTORY ${SDL_MIXER_INCLUDE_DIR})

add_library(SDL_mixer IMPORTED STATIC)
target_include_directories(SDL_mixer
    INTERFACE
        ${SDL_MIXER_INCLUDE_DIR}
)
target_link_libraries(SDL_mixer
    INTERFACE
        ${SDL_MIXER_LIBRARY_DIR}/${CMAKE_STATIC_LIBRARY_PREFIX}opusfile${CMAKE_STATIC_LIBRARY_SUFFIX}
        ${SDL_MIXER_LIBRARY_DIR}/${CMAKE_STATIC_LIBRARY_PREFIX}ogg${CMAKE_STATIC_LIBRARY_SUFFIX}
        ${SDL_MIXER_LIBRARY_DIR}/${CMAKE_STATIC_LIBRARY_PREFIX}opus${CMAKE_STATIC_LIBRARY_SUFFIX}
        ${SDL_MIXER_LIBRARY_DIR}/${CMAKE_STATIC_LIBRARY_PREFIX}wavpack${CMAKE_STATIC_LIBRARY_SUFFIX}
        ${SDL_MIXER_LIBRARY_DIR}/${CMAKE_STATIC_LIBRARY_PREFIX}xmp${CMAKE_STATIC_LIBRARY_SUFFIX}
)
set_target_properties(SDL_mixer PROPERTIES
    IMPORTED_LOCATION
        ${SDL_MIXER_LIBRARY_DIR}/${CMAKE_STATIC_LIBRARY_PREFIX}SDL2_mixer${CMAKE_STATIC_LIBRARY_SUFFIX}
)

add_dependencies(SDL_mixer 3rd_SDL_mixer)
