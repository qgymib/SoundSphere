set(SDL_MIXER_ROOT ${CMAKE_CURRENT_SOURCE_DIR}/third_party/SDL_mixer)
set(SDL_MIXER_BUILD_DIR ${CMAKE_BINARY_DIR}/SDL_mixer-build)
set(SDL_MIXER_INSTALL_DIR ${CMAKE_BINARY_DIR}/SDL_mixer-install)
set(SDL_MIXER_INCLUDE_DIR ${SDL_MIXER_INSTALL_DIR}/include)
set(SDL_MIXER_LIBRARY_DIR ${SDL_MIXER_INSTALL_DIR}/lib)

if (MSVC)
    set(SDL_MIXER_LIBRARY_FILE ${SDL_MIXER_LIBRARY_DIR}/${CMAKE_STATIC_LIBRARY_PREFIX}SDL2_mixer-static${CMAKE_STATIC_LIBRARY_SUFFIX})
    set(XMP_LIBRARY_FILE ${SDL_MIXER_LIBRARY_DIR}/libxmp-static${CMAKE_STATIC_LIBRARY_SUFFIX})
else()
    set(SDL_MIXER_LIBRARY_FILE ${SDL_MIXER_LIBRARY_DIR}/${CMAKE_STATIC_LIBRARY_PREFIX}SDL2_mixer${CMAKE_STATIC_LIBRARY_SUFFIX})
    set(XMP_LIBRARY_FILE ${SDL_MIXER_LIBRARY_DIR}/libxmp${CMAKE_STATIC_LIBRARY_SUFFIX})
endif()

set(OPUSFILE_LIBRARY_FILE ${SDL_MIXER_LIBRARY_DIR}/${CMAKE_STATIC_LIBRARY_PREFIX}opusfile${CMAKE_STATIC_LIBRARY_SUFFIX})
set(OGG_LIBRARY_FILE ${SDL_MIXER_LIBRARY_DIR}/${CMAKE_STATIC_LIBRARY_PREFIX}ogg${CMAKE_STATIC_LIBRARY_SUFFIX})
set(OPUS_LIBRARY_FILE ${SDL_MIXER_LIBRARY_DIR}/${CMAKE_STATIC_LIBRARY_PREFIX}opus${CMAKE_STATIC_LIBRARY_SUFFIX})
set(WAVEPACK_LIBRARY_FILE ${SDL_MIXER_LIBRARY_DIR}/libwavpack${CMAKE_STATIC_LIBRARY_SUFFIX})

include(ExternalProject)

find_package(SDL2 REQUIRED CONFIG REQUIRED COMPONENTS SDL2)
get_target_property(sdl2_library SDL2::SDL2 IMPORTED_IMPLIB)

ExternalProject_Add(3rd_SDL_mixer
    SOURCE_DIR  ${SDL_MIXER_ROOT}
    BINARY_DIR  ${SDL_MIXER_BUILD_DIR}
    INSTALL_DIR ${SDL_MIXER_INSTALL_DIR}
    CMAKE_ARGS
        -DBUILD_SHARED_LIBS:BOOL=OFF
        -DBUILD_TESTING:BOOL=OFF
        -DSDL2MIXER_SAMPLES:BOOL=OFF
        -DSDL2MIXER_DEPS_SHARED:BOOL=OFF
        -DSDL2MIXER_VENDORED:BOOL=ON
        -DCMAKE_INSTALL_PREFIX:PATH=<INSTALL_DIR>
        -DSDL2MIXER_DEBUG_POSTFIX:STRING=
        -DSDL2_LIBRARY:PATH=${sdl2_library}
        -DSDL2_INCLUDE_DIR:PATH=${SDL2_INCLUDE_DIRS}
    BUILD_BYPRODUCTS
        ${SDL_MIXER_LIBRARY_FILE}
        ${OPUSFILE_LIBRARY_FILE}
        ${OGG_LIBRARY_FILE}
        ${OPUS_LIBRARY_FILE}
        ${WAVEPACK_LIBRARY_FILE}
        ${XMP_LIBRARY_FILE}
)

file(MAKE_DIRECTORY ${SDL_MIXER_INCLUDE_DIR})

add_library(SDL_mixer IMPORTED STATIC)
target_include_directories(SDL_mixer
    INTERFACE
        ${SDL_MIXER_INCLUDE_DIR}
)
target_link_libraries(SDL_mixer
    INTERFACE
        ${OPUSFILE_LIBRARY_FILE}
        ${OGG_LIBRARY_FILE}
        ${OPUS_LIBRARY_FILE}
        ${WAVEPACK_LIBRARY_FILE}
        ${XMP_LIBRARY_FILE}
)
set_target_properties(SDL_mixer PROPERTIES
    IMPORTED_LOCATION
        ${SDL_MIXER_LIBRARY_FILE}
)

if (WIN32)
target_link_libraries(SDL_mixer
    INTERFACE
        Winmm
)
endif()

add_dependencies(SDL_mixer 3rd_SDL_mixer)
